<!DOCTYPE html>
<html amp lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  {{#if page_metadata.title}}
  <meta property="title" content="{{page_metadata.title}}" />
  <meta property="og:title" content="{{page_metadata.title}}" />
  <meta name="twitter:title" content="{{page_metadata.title}}" />
  {{/if}}

  {{{open_graph_tags}}}

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  {{#if page_metadata.title}}
  <title>{{page_metadata.title}}</title>
  {{else}}
  <title>{{title}}</title>
  {{/if}}

  <script async src="https://cdn.ampproject.org/v0.js"></script>

  <style amp-boilerplate>
    body {
      -webkit-animation: -amp-start 8s steps(1, end) 0s 1 normal both;
      -moz-animation: -amp-start 8s steps(1, end) 0s 1 normal both;
      -ms-animation: -amp-start 8s steps(1, end) 0s 1 normal both;
      animation: -amp-start 8s steps(1, end) 0s 1 normal both
    }

    @-webkit-keyframes -amp-start {
      from {
        visibility: hidden
      }

      to {
        visibility: visible
      }
    }

    @-moz-keyframes -amp-start {
      from {
        visibility: hidden
      }

      to {
        visibility: visible
      }
    }

    @-ms-keyframes -amp-start {
      from {
        visibility: hidden
      }

      to {
        visibility: visible
      }
    }

    @-o-keyframes -amp-start {
      from {
        visibility: hidden
      }

      to {
        visibility: visible
      }
    }

    @keyframes -amp-start {
      from {
        visibility: hidden
      }

      to {
        visibility: visible
      }
    }
  </style>
  <noscript>
    <style amp-boilerplate>
      body {
        -webkit-animation: none;
        -moz-animation: none;
        -ms-animation: none;
        animation: none
      }
    </style>
  </noscript>

  <style amp-custom>
    @font-face {
      font-family: "Ioskeley Mono";
      src: url("/fonts/IoskeleyMono-Regular.woff2") format("woff2");
      font-style: normal;
      font-weight: 400;
      font-display: swap;
    }

    @font-face {
      font-family: "Ioskeley Mono";
      src: url("/fonts/IoskeleyMono-Italic.woff2") format("woff2");
      font-style: italic;
      font-weight: 400;
      font-display: swap;
    }

    @font-face {
      font-family: "Ioskeley Mono";
      src: url("/fonts/IoskeleyMono-SemiBold.woff2") format("woff2");
      font-style: normal;
      font-weight: 600;
      font-display: swap;
    }

    @font-face {
      font-family: "Ioskeley Mono";
      src: url("/fonts/IoskeleyMono-SemiBoldItalic.woff2") format("woff2");
      font-style: italic;
      font-weight: 600;
      font-display: swap;
    }

    @font-face {
      font-family: "Ioskeley Mono";
      src: url("/fonts/IoskeleyMono-Bold.woff2") format("woff2");
      font-style: normal;
      font-weight: 700;
      font-display: swap;
    }

    @font-face {
      font-family: "Ioskeley Mono";
      src: url("/fonts/IoskeleyMono-BoldItalic.woff2") format("woff2");
      font-style: italic;
      font-weight: 700;
      font-display: swap;
    }

    body {
      font-family: "Ioskeley Mono", "IBM Plex Mono", "SF Mono", Consolas, monospace;
      margin: 0;
      padding: 0;
      padding-bottom: 60px;
      letter-spacing: -0.01em;
      line-height: 1.6;
      color: #000000;
      background-color: #ffffff;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      font-weight: 400;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 24px;
    }

    h1, h2, h3, h4, h5, h6 {
      margin: 0 0 16px 0;
      font-weight: 600;
      line-height: 1.3;
      color: #000000;
      letter-spacing: -0.05em;
    }

    h1 { 
      font-size: 36px; 
      font-weight: 600;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-top: 40px;
    }
    h2 { 
      font-size: 28px; 
      margin-top: 36px;
    }
    h3 { 
      font-size: 24px; 
      margin-top: 32px;
    }

    p {
      margin: 0 0 20px 0;
      color: #000000;
      font-size: 16px;
      line-height: 1.7;
    }

    a {
      color: #000000;
      text-decoration: underline;
      text-decoration-color: #e5e5e5;
      text-underline-offset: 3px;
    }

    ul, ol {
      margin: 0 0 20px 0;
      padding-left: 20px;
    }

    li {
      margin-bottom: 4px;
      color: #000000;
      line-height: 1.7;
    }

    code {
      font-family: "Ioskeley Mono", "JetBrains Mono", "Fira Code", "SF Mono", Consolas, monospace;
      font-size: 13px;
      background-color: #fafafa;
      padding: 2px 6px;
      border-radius: 4px;
      color: #000000;
      font-weight: 400;
    }

    code[class*="language-"],
    pre[class*="language-"] {
      font-family: "Ioskeley Mono", "JetBrains Mono", "Fira Code", "SF Mono", Consolas, monospace;
      letter-spacing: -0.01em;
    }

    pre {
      background-color: #fafafa;
      padding: 16px 20px;
      border-radius: 6px;
      overflow-x: auto;
      margin: 24px 0;
      border: 1px solid #e5e5e5;
    }

    pre code {
      background: none;
      padding: 0;
      font-size: 14px;
      font-weight: 400;
      border: none;
    }

    pre[class*="language-"],
    pre,
    pre code,
    code[class*="language-"] {
      color: #24292f;
    }

    pre[class*="language-"],
    pre {
      background: #f6f8fa;
      border: 1px solid #e5e5e5;
    }

    :not(pre) > code[class*="language-"] {
      background: #f6f8fa;
    }

    .token.comment,
    .token.prolog,
    .token.doctype,
    .token.cdata {
      color: #6e7781;
    }

    .token.punctuation,
    .token.operator {
      color: #24292f;
    }

    .token.property,
    .token.tag,
    .token.boolean,
    .token.number,
    .token.constant,
    .token.symbol,
    .token.deleted {
      color: #0550ae;
    }

    .token.selector,
    .token.attr-name,
    .token.string,
    .token.char,
    .token.builtin,
    .token.inserted {
      color: #0a3069;
    }

    .token.atrule,
    .token.attr-value,
    .token.keyword {
      color: #cf222e;
    }

    .token.function,
    .token.class-name {
      color: #8250df;
    }

    .token.regex,
    .token.important,
    .token.variable {
      color: #953800;
    }

    @media (prefers-color-scheme: dark) {
      pre[class*="language-"],
      pre,
      pre code,
      code[class*="language-"] {
        color: #c9d1d9;
      }

      pre[class*="language-"],
      pre {
        background: #161b22;
        border-color: #2a2a2a;
      }

      :not(pre) > code[class*="language-"] {
        background: #161b22;
      }

      .token.comment,
      .token.prolog,
      .token.doctype,
      .token.cdata {
        color: #8b949e;
      }

      .token.punctuation,
      .token.operator {
        color: #c9d1d9;
      }

      .token.property,
      .token.tag,
      .token.boolean,
      .token.number,
      .token.constant,
      .token.symbol,
      .token.deleted {
        color: #79c0ff;
      }

      .token.selector,
      .token.attr-name,
      .token.string,
      .token.char,
      .token.builtin,
      .token.inserted {
        color: #a5d6ff;
      }

      .token.atrule,
      .token.attr-value,
      .token.keyword {
        color: #ff7b72;
      }

      .token.function,
      .token.class-name {
        color: #d2a8ff;
      }

      .token.regex,
      .token.important,
      .token.variable {
        color: #ffa657;
      }
    }

    blockquote {
      margin: 24px 0;
      padding: 0 0 0 20px;
      border-left: 2px solid #e5e5e5;
      font-style: normal;
    }

    blockquote p {
      margin: 0;
      color: #000000;
      font-size: 16px;
    }

    .footnote-reference {
      font-size: 0.78em;
      line-height: 0;
    }

    .footnote-reference a {
      color: #666666;
      font-weight: 600;
      text-decoration: none;
    }

    .footnote-definition {
      margin: 8px 0;
      color: #666666;
      font-size: 14px;
      line-height: 1.6;
      scroll-margin-top: 24px;
    }

    .footnote-definition-label {
      color: #000000;
      font-weight: 600;
      margin-right: 8px;
    }

    .footnote-definition p {
      display: inline;
      margin: 0;
      color: inherit;
      font-size: inherit;
      line-height: inherit;
    }

    .blog-title-container {
      padding: 16px 0 40px 0;
    }

    .blog-title {
      position: relative;
      display: inline-block;
      font-size: 48px;
      font-weight: 500;
      margin-bottom: 12px;
      color: #241f1c;
      letter-spacing: -0.025em;
      line-height: 1.1;
    }

    .blog-title::after {
      position: absolute;
      inset: 0 auto auto 0;
      color: #241f1c;
      content: "~/techulus";
      opacity: 0;
      pointer-events: none;
      white-space: nowrap;
    }

    .blog-title:hover,
    .blog-title:focus-visible {
      color: transparent;
    }

    .blog-title:hover::after,
    .blog-title:focus-visible::after {
      animation: title-scramble 720ms steps(1, end) both;
    }

    @keyframes title-scramble {
      0% { content: "~/t#chulus"; opacity: 1; }
      14% { content: "~>te_hlus"; opacity: 1; }
      28% { content: "~/tec^ulu"; opacity: 1; }
      42% { content: "~/techu|s"; opacity: 1; }
      56% { content: "~/tecklus"; opacity: 1; }
      70% { content: "~/techul$"; opacity: 1; }
      84% { content: "~/techulu"; opacity: 1; }
      100% { content: "~/techulus"; opacity: 1; }
    }

    @media (prefers-color-scheme: dark) {
      .blog-title {
        color: #f0e9e1;
      }

      .blog-title::after {
        color: #f0e9e1;
      }
    }

    footer {
      margin-top: 100px;
      padding: 60px 0;
      text-align: left;
    }

    footer small {
      color: #666666;
      font-size: 14px;
      line-height: 1.6;
    }

    footer a {
      color: #666666;
      text-decoration: none;
    }

    img, amp-img {
      max-width: 100%;
      height: auto;
      margin: 24px 0;
      display: block;
      border-radius: 6px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 32px 0;
      font-size: 14px;
    }

    th, td {
      padding: 12px;
      text-align: left;
      border-bottom: 1px solid #e4e4e7;
    }

    th {
      font-weight: 600;
      color: #18181b;
      background-color: #fafafa;
    }

    hr {
      border: none;
      height: 1px;
      background-color: #e4e4e7;
      margin: 32px 0 16px;
    }

    @media (max-width: 768px) {
      .container {
        padding: 0 20px;
      }
      
      .blog-title {
        font-size: 36px;
      }
      
      body {
        padding-bottom: 48px;
      }
      
      .blog-title-container {
        padding: 12px 0 32px 0;
      }
      
      h1 { 
        font-size: 28px; 
        margin-top: 32px;
      }
      h2 { 
        font-size: 24px; 
        margin-top: 28px;
      }
      h3 { 
        font-size: 20px; 
        margin-top: 24px;
      }
      
      footer {
        margin-top: 80px;
        padding: 48px 0;
      }
      
      table {
        font-size: 13px;
      }
      
      th, td {
        padding: 8px;
      }
    }
  </style>
</head>

<body>
  <main class="container">

    <hgroup class="blog-title-container">
      <h1 class="blog-title">{{title}}</h1>
    </hgroup>

    {{{content}}}

  </main>
  <footer class="container">
    <small>
      Built with
      <a href="https://rustyink.cli.rs" target="_blank" rel="noopener noreferrer">RustyInk</a>
      •
      <a target="_blank" rel="noopener noreferrer" href="https://github.com/arjunkomath/rustyink">
        Source code
      </a>
    </small>
  </footer>
</body>

</html>
